{
  "name": "node-wp-api-client",
  "version": "0.1.0",
  "description": "Type-safe WordPress REST API client (GET only) with response types that follow your query (_fields, _embed, context)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "prepare": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "keywords": [
    "wordpress",
    "wp-api",
    "rest-api",
    "typescript",
    "sdk"
  ],
  "author": "Hidetaka Okamoto",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hideokamoto/node-wp-api-client.git"
  },
  "bugs": "https://github.com/hideokamoto/node-wp-api-client/issues",
  "homepage": "https://github.com/hideokamoto/node-wp-api-client#readme",
  "engines": {
    "node": ">=20.19"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
